{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/:path*/",
      "destination": "https://uychi-hub-api.onrender.com/api/:path*/"
    },
    {
      "source": "/api/:path*",
      "destination": "https://uychi-hub-api.onrender.com/api/:path*/"
    }
  ]
}
